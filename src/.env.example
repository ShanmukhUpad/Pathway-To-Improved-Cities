# ── Socrata App Tokens (optional but strongly recommended) ────────────────────
# One free token from https://dev.socrata.com/register works for ALL portals.
# Set it in all 6 variables below, or just the cities you plan to use.
CHICAGO_DATA_PORTAL_TOKEN=your_token_here
NYC_DATA_PORTAL_TOKEN=your_token_here
LA_DATA_PORTAL_TOKEN=your_token_here
SF_DATA_PORTAL_TOKEN=your_token_here
AUSTIN_DATA_PORTAL_TOKEN=your_token_here
SEATTLE_DATA_PORTAL_TOKEN=your_token_here

# ── US Census Bureau ACS API Key ─────────────────────────────────────────────
# Required for the Socioeconomics tab on all non-Chicago cities.
# Free key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_key_here

# ── Mapbox Token (optional — unlocks satellite and street map styles) ─────────
MAPBOX_TOKEN=your_mapbox_token_here
